# Signs session cookies. Without it the server uses an ephemeral key, so
# sessions are dropped on every restart. Set it in production.
# Generate a 64-byte (128 hex char) value with: openssl rand -hex 64
APP_SECRET=

# SQLx connection string. Defaults to sqlite://schedule.db?mode=rwc.
DATABASE_URL=sqlite://schedule.db?mode=rwc

# Directory served at /. Defaults to frontend; use frontend/dist in prod.
FRONTEND_DIR=frontend

# Optional: tracing filter. Defaults to schedule=debug,tower_http=info.
# RUST_LOG=schedule=info,tower_http=info
